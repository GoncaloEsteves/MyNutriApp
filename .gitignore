# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
backend_api/.bundle

# Ignore all environment files.
backend_api/.env*

# Ignore all logfiles and tempfiles.
backend_api/log/*
backend_api/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
backend_api/tmp/pids/*
!/backend_api/tmp/pids/
!/backend_api/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
backend_api/storage/*
!/backend_api/storage/.keep
backend_api/tmp/storage/*
!/backend_api/tmp/storage/
!/backend_api/tmp/storage/.keep

backend_api/public/assets

# Ignore key files for decrypting credentials and more.
backend_api/config/*.key

# dependencies
/frontend_client/node_modules
/frontend_client/.pnp
/frontend_client/.pnp.js

# testing
/frontend_client/coverage

# production
/frontend_client/build

# misc
/frontend_client/.DS_Store
/frontend_client/.env.local
/frontend_client/.env.development.local
/frontend_client/.env.test.local
/frontend_client/.env.production.local

/frontend_client/npm-debug.log*
/frontend_client/yarn-debug.log*
/frontend_client/yarn-error.log*